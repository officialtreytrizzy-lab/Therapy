{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "functions": {
    "api/guide.js": {
      "maxDuration": 60
    },
    "api/guide-route.js": {
      "maxDuration": 60
    },
    "api/firebase-account.js": {
      "maxDuration": 30
    },
    "api/firebase-account-route.js": {
      "maxDuration": 60
    },
    "api/auth-email-link.js": {
      "maxDuration": 30
    },
    "api/deletion-worker.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/deletion-worker",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://www.google.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.googleapis.com https://firebaseappcheck.googleapis.com https://firebaseinstallations.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://www.googleapis.com; frame-src https://*.firebaseapp.com https://www.google.com; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/healthz",
      "destination": "/api/healthz.js"
    },
    {
      "source": "/api/firebase-config",
      "destination": "/api/firebase-config.js"
    },
    {
      "source": "/api/auth-email-link",
      "destination": "/api/auth-email-link.js"
    },
    {
      "source": "/api/firebase-account",
      "destination": "/api/firebase-account-route.js"
    },
    {
      "source": "/api/deletion-worker",
      "destination": "/api/deletion-worker.js"
    },
    {
      "source": "/api/guide",
      "destination": "/api/guide-route.js"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
