{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "functions": {
    "api/guide.js": { "maxDuration": 60 },
    "api/firebase-account.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/healthz", "destination": "/api/healthz.js" },
    { "source": "/api/firebase-config", "destination": "/api/firebase-config.js" },
    { "source": "/api/firebase-account", "destination": "/api/firebase-account.js" },
    { "source": "/api/guide", "destination": "/api/guide.js" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
