rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isCoupleMember(coupleId) {
      return signedIn()
        && exists(/databases/$(database)/documents/couples/$(coupleId))
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
    }

    function onlySafeProfileFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'displayName',
        'pronouns',
        'photoURL',
        'personalIntake',
        'onboardingComplete',
        'updatedAt'
      ]);
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create, delete: if false;
      allow update: if isSelf(uid) && onlySafeProfileFieldsChanged();

      match /privateInteractions/{interactionId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /secretAssignments/{assignmentId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /bridgePrompts/{promptId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /privateMemories/{memoryId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /cloudExercises/{exerciseId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /blockList/{blockedUid} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /guidedSessions/{sessionId} {
        allow read: if isSelf(uid);
        allow write: if false;

        match /turns/{turnId} {
          allow read: if isSelf(uid);
          allow write: if false;
        }

        match /presence/{presenceUid} {
          allow read: if isSelf(uid);
          allow write: if false;
        }

        match /sharedHomework/{homeworkId} {
          allow read: if isSelf(uid);
          allow write: if false;
        }
      }

      match /interactionLedger/{eventId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }
    }

    match /memberDirectory/{memberCode} {
      allow read, write: if false;
    }

    match /partnerInvites/{inviteId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow write: if false;
    }

    match /couples/{coupleId} {
      allow read: if isCoupleMember(coupleId);
      allow write: if false;

      match /members/{uid} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /guide/{documentId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /dossierCorrections/{correctionId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /unlinkRequests/{uid} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /sharedDeletionConfirmations/{uid} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /derivedSignals/{signalId} {
        allow read, write: if false;
      }

      match /interactionLedger/{eventId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /liveSessions/{sessionId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;

        match /turns/{turnId} {
          allow read: if isCoupleMember(coupleId);
          allow write: if false;
        }

        match /presence/{uid} {
          allow read: if isCoupleMember(coupleId);
          allow write: if false;
        }

        match /sharedHomework/{homeworkId} {
          allow read: if isCoupleMember(coupleId);
          allow write: if false;
        }
      }

      match /sessions/{sessionId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;

        match /messages/{messageId} {
          allow read: if isCoupleMember(coupleId);
          allow write: if false;
        }
      }

      match /goals/{goalId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /agreements/{agreementId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /sharedMemories/{memoryId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }

      match /timeline/{eventId} {
        allow read: if isCoupleMember(coupleId);
        allow write: if false;
      }
    }

    match /deletionRequests/{uid} {
      allow read: if isSelf(uid);
      allow write: if false;
    }

    match /abuseReports/{reportId} {
      allow read, write: if false;
    }

    match /systemAuditEvents/{eventId} {
      allow read, write: if false;
    }

    match /systemRateLimits/{limitId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
